---
/**
 * ArcSite API — landing hero.
 * Aesthetic: "blueprint / field-engineered" — a technical measurement grid,
 * orange ink on near-black, mono annotations, and a live request window as the
 * hero showpiece. Built to be memorable without sacrificing developer clarity.
 */
---

<div class="lp">
  <div class="lp-grid" aria-hidden="true"></div>
  <div class="lp-glow" aria-hidden="true"></div>
  <div class="lp-crosshair lp-crosshair--tl" aria-hidden="true"></div>
  <div class="lp-crosshair lp-crosshair--br" aria-hidden="true"></div>

  <section class="lp-hero">
    <div class="lp-copy">
      <p class="lp-eyebrow"><span class="lp-pulse"></span>Developer&nbsp;Docs <span class="sep">/</span> v1 <span class="sep">/</span> REST</p>
      <h1 class="lp-title">The ArcSite<br /><span class="accent">API.</span></h1>
      <p class="lp-tagline">
        Programmatic access to ArcSite — projects, drawings, proposals, and the
        integrations that move your deals forward.
      </p>
      <div class="lp-cta">
        <a class="lp-btn lp-btn--primary" href="/quickstart/">
          Get started
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="lp-btn lp-btn--ghost" href="https://user.arcsiteapp.com#/admin" target="_blank" rel="noopener noreferrer">
          Get an API token
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
        </a>
      </div>
    </div>

    <div class="lp-window" aria-hidden="true">
      <div class="win-rule"><span>01</span><span>02</span><span>03</span><span>04</span><span>05</span></div>
      <div class="win-bar">
        <span class="win-dot"></span><span class="win-dot"></span><span class="win-dot"></span>
        <span class="win-name">GET /v1/projects</span>
        <span class="win-badge">200&nbsp;OK</span>
      </div>
      <pre class="win-req"><span class="c-cmd">curl</span> <span class="c-str">"https://api.arcsite.com/v1/projects"</span> \
  <span class="c-flag">-H</span> <span class="c-str">"Authorization: Bearer </span><span class="c-tok">$TOKEN</span><span class="c-str">"</span></pre>
      <pre class="win-res">[
  &#123;
    <span class="c-key">"id"</span>: <span class="c-num">36029621652695040</span>,
    <span class="c-key">"name"</span>: <span class="c-str">"Maple St. Reroof"</span>,
    <span class="c-key">"job_number"</span>: <span class="c-str">"144111"</span>,
    <span class="c-key">"customer"</span>: &#123; <span class="c-key">"name"</span>: <span class="c-str">"Jack"</span> &#125;,
    <span class="c-key">"tags"</span>: [<span class="c-str">"roofing"</span>, <span class="c-str">"q3"</span>],
    <span class="c-key">"archived"</span>: <span class="c-bool">false</span>
  &#125;
]</pre>
    </div>
  </section>

  <section class="lp-features">
    <a class="feat" href="/quickstart/">
      <span class="feat-no">01</span>
      <h3>REST, the way you expect</h3>
      <p>Resource-oriented URLs, JSON bodies, standard verbs and status codes. If you've used a modern REST API, you already know how this one works.</p>
      <span class="feat-go">Quickstart →</span>
    </a>
    <a class="feat" href="/authentication/">
      <span class="feat-no">02</span>
      <h3>Auth in a single header</h3>
      <p>Send <code>Authorization: Bearer &lt;token&gt;</code> and you're in. Issue and rotate tokens from the admin console — no OAuth dance.</p>
      <span class="feat-go">Authentication →</span>
    </a>
    <a class="feat" href="/projects/">
      <span class="feat-no">03</span>
      <h3>Projects, drawings &amp; proposals</h3>
      <p>Create projects, import PDFs as drawings, pull takeoff and proposal line items, and export signed proposals — the full field-to-quote workflow.</p>
      <span class="feat-go">API reference →</span>
    </a>
    <a class="feat" href="/webhooks/">
      <span class="feat-no">04</span>
      <h3>Webhooks &amp; CRM integrations</h3>
      <p>Subscribe to real-time events and connect ArcSite to Salesforce, Zoho CRM, and improveit360 with first-class, documented flows.</p>
      <span class="feat-go">Events &amp; integrations →</span>
    </a>
  </section>
</div>

<style>
  .lp {
    position: relative;
    margin-inline: auto;
    max-width: 78rem;
    padding-inline: clamp(1rem, 4vw, 2.5rem);
    isolation: isolate;
    overflow: clip;
  }

  /* ---- Blueprint atmosphere -------------------------------------------- */
  .lp-grid {
    position: absolute;
    inset: -10% -20% auto -20%;
    height: 720px;
    z-index: -2;
    background-image:
      linear-gradient(to right, color-mix(in oklab, var(--sl-color-gray-5) 55%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in oklab, var(--sl-color-gray-5) 55%, transparent) 1px, transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(120% 90% at 30% 0%, #000 30%, transparent 72%);
    mask-image: radial-gradient(120% 90% at 30% 0%, #000 30%, transparent 72%);
    opacity: 0.6;
  }
  .lp-glow {
    position: absolute;
    inset: -30% auto auto -10%;
    width: 70%;
    height: 620px;
    z-index: -2;
    background: radial-gradient(50% 55% at 35% 30%, color-mix(in oklab, var(--sl-color-accent) 30%, transparent), transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }
  .lp-crosshair {
    position: absolute;
    width: 13px; height: 13px;
    z-index: -1;
    opacity: 0.7;
  }
  .lp-crosshair::before, .lp-crosshair::after {
    content: ''; position: absolute; background: var(--sl-color-accent);
  }
  .lp-crosshair::before { inset: 6px 0 6px 0; }   /* horizontal */
  .lp-crosshair::after  { inset: 0 6px 0 6px; }   /* vertical */
  .lp-crosshair--tl { top: 14px; left: clamp(0.5rem, 3vw, 1.5rem); }
  .lp-crosshair--br { bottom: 18px; right: clamp(0.5rem, 3vw, 1.5rem); }

  /* ---- Hero layout ----------------------------------------------------- */
  .lp-hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(3rem, 8vw, 6.5rem) clamp(2.5rem, 6vw, 4.5rem);
  }
  @media (max-width: 56rem) {
    .lp-hero { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .lp-eyebrow {
    display: inline-flex; align-items: center; gap: 0.6ch;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--sl-color-gray-2);
    margin: 0 0 1.3rem;
  }
  .lp-eyebrow .sep { color: var(--sl-color-accent); opacity: 0.7; }
  .lp-pulse {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--sl-color-accent);
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--sl-color-accent) 70%, transparent);
    animation: lp-pulse 2.4s ease-out infinite;
  }
  @keyframes lp-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--sl-color-accent) 60%, transparent); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .lp-title {
    font-family: var(--brand-font);
    font-weight: 700;
    font-size: clamp(2.9rem, 7vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.045em;
    margin: 0 0 1.4rem;
    color: var(--sl-color-white);
  }
  .lp-title .accent {
    background: linear-gradient(96deg, var(--sl-color-accent), #ff9a5e);
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .lp-tagline {
    font-size: clamp(1.02rem, 1.5vw, 1.2rem);
    line-height: 1.62;
    color: var(--sl-color-gray-2);
    max-width: 36ch;
    margin: 0 0 2.1rem;
  }

  .lp-cta { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-bottom: 0.25rem; }
  .lp-btn {
    display: inline-flex; align-items: center; gap: 0.55ch;
    font-weight: 600; font-size: 0.96rem;
    padding: 0.72rem 1.3rem; border-radius: 999px;
    text-decoration: none; border: 1px solid transparent;
    transition: transform 0.18s cubic-bezier(.2,.7,.3,1), box-shadow 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }
  .lp-btn svg { transition: transform 0.18s cubic-bezier(.2,.7,.3,1); }
  .lp-btn--primary {
    background: var(--sl-color-accent); color: #fff;
    box-shadow: 0 10px 30px -10px color-mix(in oklab, var(--sl-color-accent) 85%, transparent);
  }
  .lp-btn--primary:hover { transform: translateY(-2px); box-shadow: 0 16px 36px -12px color-mix(in oklab, var(--sl-color-accent) 90%, transparent); }
  .lp-btn--primary:hover svg { transform: translateX(3px); }
  .lp-btn--ghost {
    color: var(--sl-color-white);
    border-color: var(--sl-color-hairline-light);
    background: color-mix(in oklab, var(--sl-color-gray-6) 35%, transparent);
  }
  .lp-btn--ghost:hover { border-color: var(--sl-color-accent); color: var(--sl-color-accent); transform: translateY(-2px); }

  /* ---- Live request window (always dark, Stripe/Vercel-style) ---------- */
  .lp-window {
    position: relative;
    border-radius: 14px;
    background: #0c0a09;
    border: 1px solid #2a2421;
    box-shadow: 0 1px 0 0 rgba(255,255,255,0.04) inset, 0 40px 80px -30px rgba(0,0,0,0.8), 0 0 0 1px rgba(0,0,0,0.4);
    overflow: hidden;
    font-family: var(--sl-font-mono);
    transform: perspective(1400px) rotateY(-6deg) rotateX(2deg);
    transform-origin: center right;
  }
  .lp-window .win-rule {
    display: flex; justify-content: space-between;
    padding: 0.35rem 0.9rem 0;
    font-size: 0.6rem; color: #4a423d; letter-spacing: 0.2em;
  }
  .win-bar {
    display: flex; align-items: center; gap: 0.5ch;
    padding: 0.7rem 1rem; border-bottom: 1px solid #1f1a17;
  }
  .win-dot { width: 11px; height: 11px; border-radius: 50%; background: #2c2622; }
  .win-bar .win-dot:first-child { background: var(--sl-color-accent); }
  .win-name { margin-left: 0.8ch; font-size: 0.8rem; color: #cdc4be; font-weight: 600; }
  .win-badge {
    margin-left: auto; font-size: 0.66rem; font-weight: 700; letter-spacing: 0.06em;
    color: #7ee0a8; background: rgba(126,224,168,0.12);
    border: 1px solid rgba(126,224,168,0.3); border-radius: 5px; padding: 0.15rem 0.5rem;
  }
  .win-req, .win-res { margin: 0; padding: 1rem 1.15rem; font-size: 0.8rem; line-height: 1.7; white-space: pre-wrap; word-break: break-word; }
  .win-req { color: #b9b0aa; border-bottom: 1px solid #16120f; background: rgba(227,87,28,0.04); }
  .win-res { color: #8a827c; }
  .c-cmd  { color: #ff7a43; font-weight: 700; }
  .c-flag { color: #c98a5e; }
  .c-str  { color: #c9b59c; }
  .c-tok  { color: var(--sl-color-accent); font-weight: 700; }
  .c-key  { color: #ff9a5e; }
  .c-num  { color: #7fb0ff; }
  .c-bool { color: #7ee0a8; }

  /* ---- Feature grid ---------------------------------------------------- */
  .lp-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--sl-color-hairline-light);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  @media (max-width: 50rem) { .lp-features { grid-template-columns: 1fr; } }
  .feat {
    position: relative;
    display: block;
    padding: 1.7rem 1.8rem 1.6rem;
    background: var(--sl-color-bg);
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .feat::after {
    content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 3px;
    background: var(--sl-color-accent); transform: scaleY(0); transform-origin: top;
    transition: transform 0.22s cubic-bezier(.2,.7,.3,1);
  }
  .feat:hover { background: color-mix(in oklab, var(--sl-color-accent) 6%, var(--sl-color-bg)); }
  .feat:hover::after { transform: scaleY(1); }
  .feat-no {
    font-family: var(--sl-font-mono); font-size: 0.74rem; letter-spacing: 0.18em;
    color: var(--sl-color-accent); opacity: 0.85;
  }
  .feat h3 {
    font-family: var(--brand-font); font-weight: 700; letter-spacing: -0.015em;
    font-size: 1.18rem; margin: 0.55rem 0 0.55rem; color: var(--sl-color-white);
  }
  .feat p { margin: 0 0 1rem; font-size: 0.92rem; line-height: 1.6; color: var(--sl-color-gray-2); }
  .feat code { font-size: 0.82em; padding: 0.1em 0.4em; border-radius: 5px; background: var(--sl-color-bg-inline-code); }
  .feat-go {
    font-family: var(--sl-font-mono); font-size: 0.78rem; font-weight: 600;
    color: var(--sl-color-text-accent);
    opacity: 0; transform: translateX(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .feat:hover .feat-go { opacity: 1; transform: translateX(0); }

  /* ---- Entrance choreography ------------------------------------------ */
  @media (prefers-reduced-motion: no-preference) {
    .lp-eyebrow, .lp-title, .lp-tagline, .lp-cta, .lp-window, .feat {
      opacity: 0;
      animation: lp-rise 0.7s cubic-bezier(.2,.7,.3,1) forwards;
    }
    .lp-eyebrow { animation-delay: 0.05s; }
    .lp-title   { animation-delay: 0.13s; }
    .lp-tagline { animation-delay: 0.22s; }
    .lp-cta     { animation-delay: 0.31s; }
    .lp-window  { animation-delay: 0.30s; animation-name: lp-rise-window; }
    .feat:nth-child(1) { animation-delay: 0.52s; }
    .feat:nth-child(2) { animation-delay: 0.59s; }
    .feat:nth-child(3) { animation-delay: 0.66s; }
    .feat:nth-child(4) { animation-delay: 0.73s; }
  }
  @keyframes lp-rise {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes lp-rise-window {
    from { opacity: 0; transform: perspective(1400px) rotateY(-6deg) rotateX(2deg) translateY(22px); }
    to   { opacity: 1; transform: perspective(1400px) rotateY(-6deg) rotateX(2deg) translateY(0); }
  }

  /* Light theme: window stays dark; soften the grid + glow */
  :global(:root[data-theme='light']) .lp-glow { opacity: 0.7; }
  :global(:root[data-theme='light']) .lp-title,
  :global(:root[data-theme='light']) .feat h3 { color: #1a1411; }
</style>
